#!/usr/bin/env bash

chosen=$(printf "ΎΑΣ Power Off\nΎΑη Reboot\nΎΗΗ Suspend\nΎΓΜ Logout\nΎΑμ Lock\n" |
  rofi -dmenu -no-show-icons -theme ~/.config/rofi/ethereal.rasi -i -p "Power Menu")

case "$chosen" in
"ΎΑΣ Power Off")
  systemctl poweroff
  ;;
"ΎΑη Reboot")
  systemctl reboot
  ;;
"ΎΗΗ Suspend")
  systemctl suspend
  ;;
"ΎΓΜ Logout")
  hyprctl dispatch exit
  ;;
"ΎΑμ Lock")
  hyprlock
  ;;
esac
